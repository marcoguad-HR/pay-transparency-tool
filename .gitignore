# Ambiente virtuale Python
.venv/
venv/

# Cache Python
__pycache__/
*.pyc
*.pyo

# File con segreti (API key, password)
.env

# Vector DB locale (dati generati, pesanti)
data/vectordb/

# PDF normativi (scaricati, non versionati)
data/documents/*.pdf

# File di build/distribuzione
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/

# Testing/Coverage
.coverage
htmlcov/
.pytest_cache/

# OS
.DS_Store

# Claude Code project settings and memory
.claude/

# Garbage files from mis-typed pip installs
=*

# Internal planning docs (not for public repo)
tasks/
PayTransparency_ChangePlan.docx

# Real config (only config.yaml.example is safe to commit)
config.yaml

# Analytics database (generato a runtime)
data/analytics.db

# Report generati
data/report_*.txt

# Lock file
data/.lock
